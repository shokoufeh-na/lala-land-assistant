<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/sonia/ontologies/2025/10/untitled-ontology-23/"
     xml:base="http://www.semanticweb.org/sonia/ontologies/2025/10/untitled-ontology-23/"
     xmlns:la="http://example.org/lala-land#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://example.org/lala-land#"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/lala-land#attracts -->

    <owl:ObjectProperty rdf:about="http://example.org/lala-land#attracts">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://example.org/lala-land#Lifestyle"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lala-land#famousFor -->

    <owl:ObjectProperty rdf:about="http://example.org/lala-land#famousFor">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://example.org/lala-land#Lifestyle"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lala-land#hasFeature -->

    <owl:ObjectProperty rdf:about="http://example.org/lala-land#hasFeature">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://example.org/lala-land#Feature"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/lala-land#hasLandmark -->

    <owl:ObjectProperty rdf:about="http://example.org/lala-land#hasLandmark">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://example.org/lala-land#Landmark"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/lala-land#averageCommuteTime -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#averageCommuteTime">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#description -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#description">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#hasArea -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#hasArea">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#hasAvgPrice -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#hasAvgPrice">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#hasCelebrityResidents -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#hasCelebrityResidents">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#hasLuxuryLevel -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#hasLuxuryLevel">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#hasPopulation -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#hasPopulation">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#hasVibe -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#hasVibe">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/lala-land#knownForCuisine -->

    <owl:DatatypeProperty rdf:about="http://example.org/lala-land#knownForCuisine">
        <rdfs:domain rdf:resource="http://example.org/lala-land#Neighborhood"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


