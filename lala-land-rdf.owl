    </owl:Class>
    


    <!-- http://example.org/lala-land#ExclusiveResidentialNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#ExclusiveResidentialNeighborhood">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryNeighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#FamilyFriendlyLuxury -->

    <owl:Class rdf:about="http://example.org/lala-land#FamilyFriendlyLuxury">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryNeighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#Feature -->

    <owl:Class rdf:about="http://example.org/lala-land#Feature"/>
    


    <!-- http://example.org/lala-land#FilmIndustry -->

    <owl:Class rdf:about="http://example.org/lala-land#FilmIndustry">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#UrbanFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#FineArtsScene -->

    <owl:Class rdf:about="http://example.org/lala-land#FineArtsScene">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#UrbanFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#GatedCommunity -->

    <owl:Class rdf:about="http://example.org/lala-land#GatedCommunity">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#ResidentialFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#HistoricArchitecture -->

    <owl:Class rdf:about="http://example.org/lala-land#HistoricArchitecture">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#ResidentialFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#HistoricLuxuryNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#HistoricLuxuryNeighborhood">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryNeighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#Landmark -->

    <owl:Class rdf:about="http://example.org/lala-land#Landmark"/>
    


    <!-- http://example.org/lala-land#Lifestyle -->

    <owl:Class rdf:about="http://example.org/lala-land#Lifestyle"/>
    


    <!-- http://example.org/lala-land#LuxuryLifestyle -->

    <owl:Class rdf:about="http://example.org/lala-land#LuxuryLifestyle">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#Lifestyle"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#LuxuryNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#LuxuryNeighborhood">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#Neighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#NaturalLandmark -->

    <owl:Class rdf:about="http://example.org/lala-land#NaturalLandmark">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#CulturalLandmark"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#Neighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#Neighborhood"/>
    


    <!-- http://example.org/lala-land#Nightlife -->

    <owl:Class rdf:about="http://example.org/lala-land#Nightlife">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#ResidentialFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#NightlifeLifestyle -->

    <owl:Class rdf:about="http://example.org/lala-land#NightlifeLifestyle">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryLifestyle"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#NightlifeLuxuryNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#NightlifeLuxuryNeighborhood">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryNeighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#OceanView -->

    <owl:Class rdf:about="http://example.org/lala-land#OceanView">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#ResidentialFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#ResidentialFeature -->

    <owl:Class rdf:about="http://example.org/lala-land#ResidentialFeature">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#Feature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#ShoppingDistrict -->

    <owl:Class rdf:about="http://example.org/lala-land#ShoppingDistrict">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#ResidentialFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#ShoppingLandmark -->

    <owl:Class rdf:about="http://example.org/lala-land#ShoppingLandmark">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#CulturalLandmark"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#ShoppingLuxuryNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#ShoppingLuxuryNeighborhood">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryNeighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#ShortCommuteElite -->

    <owl:Class rdf:about="http://example.org/lala-land#ShortCommuteElite">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#LuxuryNeighborhood"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#TechInnovation -->

    <owl:Class rdf:about="http://example.org/lala-land#TechInnovation">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#UrbanFeature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#UltraLuxuryNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#UltraLuxuryNeighborhood">
