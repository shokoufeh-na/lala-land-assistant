    </owl:Class>
    


    <!-- http://example.org/lala-land#UrbanFeature -->

    <owl:Class rdf:about="http://example.org/lala-land#UrbanFeature">
        <rdfs:subClassOf rdf:resource="http://example.org/lala-land#Feature"/>
    </owl:Class>
    


    <!-- http://example.org/lala-land#UrbanLuxuryNeighborhood -->

    <owl:Class rdf:about="http://example.org/lala-land#UrbanLuxuryNeighborhood">
